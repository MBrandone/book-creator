{
  "name": "book-creator-web-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run db:migrate && tsx scripts/build-sw.ts && next dev --turbopack",
    "build": "tsx scripts/build-sw.ts && next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "tsx scripts/migrate.ts latest",
    "db:migrate:up": "tsx scripts/migrate.ts up",
    "db:migrate:down": "tsx scripts/migrate.ts down",
    "db:migrate:create": "tsx scripts/create-migration.ts",
    "deploy": "NODE_ENV=production tsx scripts/migrate.ts latest",
    "test:e2e": "docker-compose -f ../docker-compose.test.yml up -d && npx playwright test && docker-compose -f ../docker-compose.test.yml down",
    "test:e2e:ui": "docker-compose -f ../docker-compose.test.yml up -d && npx playwright test --ui && docker-compose -f ../docker-compose.test.yml down"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1067.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "kysely": "^0.29.2",
    "lucide-react": "^1.17.0",
    "minio": "^8.0.7",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "replicate": "^1.4.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "workbox-core": "^7.4.1",
    "workbox-expiration": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/minio": "^7.1.0",
    "@types/node": "^20.19.43",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
