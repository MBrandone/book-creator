# Application Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bookcreator
POSTGRES_USER=bookuser
POSTGRES_PASSWORD=bookpass

# Storage Configuration
STORAGE_PROVIDER=aws-s3
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_USE_SSL=false
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=book-images
STORAGE_REGION=eu-west-1
STORAGE_PUBLIC_BASE_URL=http://localhost:9000

# AI Services Configuration
REPLICATE_API_TOKEN=
STORY_PROVIDER=ollama
IMAGE_GENERATION_PROVIDER=mock
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# Image Upload Configuration
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# Generation Configuration
STORY_GENERATION_TIMEOUT=60000
IMAGE_GENERATION_TIMEOUT=90000

# Logging
LOGS_PROVIDER=console
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
