{
	"PostFileWrite": [
		{
			"matcher": "*.js",
			"command": "npm run check ${file}"
		},
		{
			"matcher": "*.ts",
			"command": "npm run check ${file}"
		},
		{
			"matcher": "*.tsx",
			"command": "npm run check ${file}"
		},
		{
			"matcher": "*.json",
			"command": "npm run check ${file}"
		}
	],
	"OnTaskComplete": [
		{
			"description": "verify build is okay when task finished",
			"matcher": "build",
			"command": "npm run build"
		},
		{
			"description": "verify e2e test pass when task finished",
			"matcher": "test",
			"command": "npm run test:e2e"
		}
	]
}
